# --- Server ---
NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:3000

# --- Database ---
# Local Docker: mongodb://localhost:27017/vaultledger
# Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/vaultledger
MONGO_URI=mongodb://localhost:27017/vaultledger

# --- JWT ---
# Generate strong secrets with: openssl rand -hex 64
JWT_ACCESS_SECRET=replace_me_with_a_long_random_value
JWT_REFRESH_SECRET=replace_me_with_a_different_long_random_value
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Encryption ---
# 32-byte (64 hex char) key for AES-256-GCM field-level encryption
# Generate with: openssl rand -hex 32
FIELD_ENCRYPTION_KEY=replace_me_with_a_64_char_hex_string

# --- MFA ---
MFA_ISSUER=VaultLedger

# --- Rate limiting ---
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
